# Variáveis de Ambiente — AvaliaProj v2
# Copie este arquivo para .env.local e preencha os valores
# NÃO commite o arquivo .env.local no repositório!

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Gere um secret seguro com: openssl rand -base64 32
NEXTAUTH_SECRET=seu_secret_super_seguro_aqui

# URL de produção no Vercel (ou http://localhost:3000 para dev)
NEXTAUTH_URL=https://sistema-avali-projetos.vercel.app

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Encontre em: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
